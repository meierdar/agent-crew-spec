#!/usr/bin/env bash
# ai-board-gen — Generate a Kanban-style BOARD.md from story frontmatter
# Outputs to stdout — redirect to BOARD.md at project root
# Zero dependencies beyond bash, grep, sed, awk

set +e

AI_DIR=".ai"
STORIES_DIR="$AI_DIR/stories"
EPICS_DIR="$AI_DIR/epics"

get_fm() {
    local file="$1" key="$2"
    sed -n '/^---$/,/^---$/p' "$file" | grep "^${key}:" | sed "s/^${key}: *//;s/\"//g" | head -1
}

# Collect stories per status into newline-separated strings
S_BACKLOG=""
S_READY=""
S_IN_PROGRESS=""
S_REVIEW=""
S_DONE=""
N_BACKLOG=0
N_READY=0
N_IN_PROGRESS=0
N_REVIEW=0
N_DONE=0

for f in "$STORIES_DIR"/*.md; do
    [ -f "$f" ] || continue
    status=$(get_fm "$f" "status")
    id=$(get_fm "$f" "id")
    title=$(get_fm "$f" "title")
    epic=$(get_fm "$f" "epic")
    role=$(get_fm "$f" "assigned_role")
    priority=$(get_fm "$f" "priority")
    fname=$(basename "$f")

    # Priority emoji
    case "$priority" in
        high)   prio="🔴" ;;
        medium) prio="🟡" ;;
        low)    prio="🟢" ;;
        *)      prio="⚪" ;;
    esac

    # Links are relative to project root (BOARD.md lives at root)
    line="${prio} **[${id}](.ai/stories/${fname})** ${title}<br/><sub>${role} · ${epic}</sub>"

    case "$status" in
        backlog)     S_BACKLOG="${S_BACKLOG}${line}"$'\n'; N_BACKLOG=$((N_BACKLOG + 1)) ;;
        ready)       S_READY="${S_READY}${line}"$'\n'; N_READY=$((N_READY + 1)) ;;
        in-progress) S_IN_PROGRESS="${S_IN_PROGRESS}${line}"$'\n'; N_IN_PROGRESS=$((N_IN_PROGRESS + 1)) ;;
        review)      S_REVIEW="${S_REVIEW}${line}"$'\n'; N_REVIEW=$((N_REVIEW + 1)) ;;
        done)        S_DONE="${S_DONE}${line}"$'\n'; N_DONE=$((N_DONE + 1)) ;;
    esac
done

# Count
total=$(( N_BACKLOG + N_READY + N_IN_PROGRESS + N_REVIEW + N_DONE ))

# Output
cat << 'HEADER'
# 📋 Board

> Auto-generated from story frontmatter. Do not edit manually.
> Updated by GitHub Action on every push to `.ai/stories/` or `.ai/epics/`.

HEADER

echo "**${total} stories** across all epics"
echo ""

# Active Epics summary
if ls "$EPICS_DIR"/*.md &>/dev/null; then
    echo "## Epics"
    echo ""
    for ef in "$EPICS_DIR"/*.md; do
        [ -f "$ef" ] || continue
        eid=$(get_fm "$ef" "id")
        etitle=$(get_fm "$ef" "title")
        estatus=$(get_fm "$ef" "status")
        efname=$(basename "$ef")
        case "$estatus" in
            active) icon="🔵" ;;
            done)   icon="✅" ;;
            draft)  icon="📝" ;;
            *)      icon="⚪" ;;
        esac
        echo "${icon} **[${eid}](.ai/epics/${efname})** — ${etitle}"
    done
    echo ""
fi

echo "---"
echo ""

# Kanban columns as sections (GitHub renders this well on any screen)
render_column() {
    local title="$1" count="$2" items="$3"
    echo "## ${title} (${count})"
    echo ""
    if [ "$count" -eq 0 ]; then
        echo "*No stories*"
    else
        echo "$items" | while IFS= read -r item; do
            [ -n "$item" ] && echo "- ${item}"
        done
    fi
    echo ""
}

render_column "🔧 In Progress" "$N_IN_PROGRESS" "$S_IN_PROGRESS"
render_column "👀 Review" "$N_REVIEW" "$S_REVIEW"
render_column "✅ Ready" "$N_READY" "$S_READY"
render_column "📥 Backlog" "$N_BACKLOG" "$S_BACKLOG"
render_column "🏁 Done" "$N_DONE" "$S_DONE"
